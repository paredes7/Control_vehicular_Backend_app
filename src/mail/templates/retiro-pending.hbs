{{#> base}}

<h2 style="margin:0 0 20px 0; color:#1a1a2e; font-size:22px; font-weight:600;">
  Solicitud de retiro recibida
</h2>

<p style="margin:0 0 16px 0; color:#4a4a68; font-size:15px; line-height:1.6;">
  Hemos recibido tu solicitud de retiro y está siendo revisada.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" 
  style="background:#f7f8fc; padding:20px; border-radius:10px; margin:25px 0;">
  <tr>
    <td style="color:#1a1a2e; font-size:14px; line-height:1.8;">
      
      <strong>Código de referencia:</strong><br/>
      {{referenceCode}}
      <br/><br/>

      <strong>Cuenta destino:</strong><br/>
      {{bankAccount}}
      <br/><br/>

      <strong>Monto solicitado:</strong><br/>
      {{amount}}
      <br/><br/>

      <strong>Comisión:</strong><br/>
      {{serviceFee}}
      <br/><br/>

      <strong>Total debitado:</strong><br/>
      {{totalAmount}}

    </td>
  </tr>
</table>

<hr style="border:none; border-top:1px solid #e8e8ef; margin:30px 0 20px 0;" />

<p style="margin:0; color:#4a4a68; font-size:14px;">
  Te notificaremos por correo cuando el retiro sea procesado.
</p>

<p style="margin:20px 0 0 0; color:#b0b0c0; font-size:12px;">
  © {{year}} - Todos los derechos reservados.
</p>

{{/base}}
