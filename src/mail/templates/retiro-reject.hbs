{{#> base}}

<h2 style="margin:0 0 20px 0; color:#b42318; font-size:22px; font-weight:600;">
  Retiro rechazado
</h2> 

<p style="margin:0 0 16px 0; color:#4a4a68; font-size:15px; line-height:1.6;">
  Tu solicitud de retiro no pudo ser procesada.
</p>

<table role="presentation" width="100%" cellpadding="0" cellspacing="0" 
  style="background:#fff4f4; padding:20px; border-radius:10px; margin:25px 0;">
  <tr>
    <td style="color:#1a1a2e; font-size:14px; line-height:1.8;">
      
      <strong>Cuenta destino:</strong><br/>
      {{bankAccount}}
      <br/><br/>

      {{#if payoutTxRef}}
        <strong>Motivo del rechazo:</strong><br/>
        {{payoutTxRef}}
        <br/><br/>
      {{/if}}

      <strong>Monto que sera devuelto:</strong><br/>
      {{totalAmount}}

    </td>
  </tr>
</table>

<hr style="border:none; border-top:1px solid #e8e8ef; margin:30px 0 20px 0;" />

<p style="margin:0; color:#4a4a68; font-size:14px;">
  Si consideras que esto es un error, contacta con soporte.
</p>


{{/base}}
